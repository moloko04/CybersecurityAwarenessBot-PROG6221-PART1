<Window x:Class="CybersecurityBot.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CybersecurityBot.GUI"
        mc:Ignorable="d"
        Title="Cyber Bot - Cybersecurity Awareness Bot" 
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F0F0">

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        
        <Border Grid.Row="0" CornerRadius="0,0,30,30">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF6B6B" Offset="0"/>
                    <GradientStop Color="#FF8E8E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="========================================" 
                           Foreground="#FFF0E6E6" FontSize="16" 
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="ascii" 
                           Text="CYBER BOT - CYBERSECURITY AWARENESS BOT" 
                           FontSize="22" FontWeight="Bold" 
                           Foreground="#FFFFFF" 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,5"/>

                <TextBlock Text="========================================" 
                           Foreground="#FFF0E6E6" FontSize="16" 
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Stay Safe Online - Think Before You Click!" 
                           Foreground="#FFE0E0E0" FontSize="14" 
                           HorizontalAlignment="Center" 
                           FontWeight="SemiBold"
                           Margin="0,10,0,0"/>

                <TextBlock Text="Protecting You Online" 
                           Foreground="#FFD4C4C4" FontSize="12" 
                           HorizontalAlignment="Center" 
                           FontStyle="Italic"/>
            </StackPanel>
        </Border>

        
        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      Margin="15,10,15,10">
            <StackPanel x:Name="ChatPanel"/>
        </ScrollViewer>

        
        <Border Grid.Row="2" 
                Margin="15,0,15,15" 
                CornerRadius="25" 
                Background="#FFF8F0F0" 
                Padding="10"
                BorderBrush="#FFD4A0A0"
                BorderThickness="2">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInput" 
                         Height="50" 
                         FontSize="16" 
                         Background="#FFFFFF" 
                         Foreground="#FF6B6B" 
                         BorderBrush="#FFD4A0A0" 
                         BorderThickness="1"
                         VerticalContentAlignment="Center" 
                         Padding="15"
                         KeyDown="UserInput_KeyDown"/>

                <Button Grid.Column="1" 
                        Content="SEND" 
                        Margin="10,0,0,0" 
                        FontSize="14" 
                        FontWeight="Bold" 
                        Background="#FF8E8E" 
                        Foreground="White" 
                        Click="SendButton_Click"
                        Cursor="Hand"
                        BorderBrush="#FF6B6B"
                        BorderThickness="1"/>
            </Grid>
        </Border>
    </Grid>
</Window>